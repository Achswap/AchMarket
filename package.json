{
  "name": "achmarket",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": "22.x",
    "npm": "10.x"
  },
  "scripts": {
    "start": "npm --prefix backend run start",
    "heroku-postbuild": "npm --prefix backend ci --include=dev && npm --prefix frontend ci --include=dev && npm --prefix backend run build && npm --prefix frontend run build && npm --prefix backend prune --omit=dev && rm -rf frontend/node_modules",
    "compile": "npx hardhat compile",
    "deploy": "npx hardhat run scripts/deploy.js --network arc_testnet",
    "deploy:local": "npx hardhat run scripts/deploy.js --network hardhat",
    "backend:dev": "npm --prefix backend run dev",
    "backend:start": "npm --prefix backend run start",
    "frontend:dev": "npm --prefix frontend run dev",
    "frontend:build": "npm --prefix frontend run build",
    "clean": "npx hardhat clean",
    "size": "npx hardhat size-contracts"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "hardhat": "^2.22.0",
    "hardhat-contract-sizer": "^2.10.0"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.1.0",
    "dotenv": "^17.3.1"
  }
}

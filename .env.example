# ── Deployer wallet ──────────────────────────────────────────────
DEPLOYER_PRIVATE_KEY=your_private_key_here

# ── Network ─────────────────────────────────────────────────────
RPC_URL=https://your-rpc-url-here
CHAIN_ID=1234

# ── Backend server ──────────────────────────────────────────────
# Used by backend/src/server.ts on a VPS.
PORT=8080
NODE_ENV=production
BODY_LIMIT=15mb

# ── MongoDB (for backend API) ───────────────────────────────────
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>/<db>
MONGO_DB_NAME=achmarket

# ── Cloudflare R2 (avatars + market media uploads) ─────────────
R2_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET=your_r2_bucket
# Required custom/public domain. Example: https://cdn.example.com
# Required by frontend/api/profile-avatar.ts and frontend/api/market-media.ts.
R2_PUBLIC_BASE_URL=

# ── API CORS allowlist (comma-separated) ────────────────────────
# Example: https://achmarket.app,https://www.achmarket.app
CORS_ALLOWED_ORIGINS=

# ── Optional: TheSportsDB V1 key ─────────────────────────────────
# The free V1 API uses the public key 123 when this is not set.
THE_SPORTS_DB_API_KEY=

# ── Frontend build ──────────────────────────────────────────────
# Use this only when the API is on a different origin than the frontend.
# Example: https://api.achmarket.app
VITE_API_BASE_URL=

# ── Optional: explicit factory override for live config API ──────
# Defaults to frontend/src/config/network.ts factory address
FACTORY_ADDRESS=
